{
  "name": "web",
  "private": true,
  "version": "v1.0.0",
  "description": "Constella - A visual workflow and node-based editing application",
  "author": "Constella Team",
  "type": "module",
  "main": "dist-electron/main.js",
  "engines": {
    "node": ">=20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "dev:electron": "vite",
    "dev:electron-no-backend": "cross-env SKIP_BACKEND=true vite",
    "build": "vue-tsc -b && vite build",
    "build:server": "npm --prefix ../server run build",
    "prepare:server-runtime": "node scripts/prepare-server-runtime.cjs",
    "build:electron-main": "vite build",
    "build:electron": "npm run build:server && npm run prepare:server-runtime && npm run build && electron-builder",
    "build:electron:dir": "npm run build:server && npm run prepare:server-runtime && npm run build && electron-builder --dir",
    "preview": "vite preview"
  },
  "build": {
    "appId": "com.constella.app",
    "productName": "Constella",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**",
      "dist-electron/**",
      "electron/**"
    ],
    "extraResources": [
      {
        "from": ".electron-server-runtime/dist",
        "to": "server/dist",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": ".electron-server-runtime/config",
        "to": "server/config",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": ".electron-server-runtime/node_modules",
        "to": "server/node_modules",
        "filter": [
          "!.bin"
        ]
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "public/icon/favicon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.2",
    "@types/katex": "^0.16.8",
    "@types/markdown-it": "^14.1.2",
    "bonjour-service": "^1.3.0",
    "dompurify": "^3.3.1",
    "electron-store": "^11.0.2",
    "element-plus": "^2.13.0",
    "highlight.js": "^11.11.1",
    "katex": "^0.16.27",
    "konva": "^10.0.12",
    "lib0": "^0.2.117",
    "markdown-it": "^14.1.0",
    "mermaid": "^11.12.2",
    "tdesign-icons-vue-next": "^0.4.1",
    "vue": "^3.5.26",
    "vue-i18n": "^9.14.4",
    "vue-konva": "^3.3.0",
    "y-websocket": "^3.0.0",
    "yjs": "^13.6.29"
  },
  "devDependencies": {
    "@types/bonjour": "^3.5.13",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^24.10.4",
    "@vitejs/plugin-vue": "^6.0.3",
    "@vue/tsconfig": "^0.8.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^39.2.7",
    "electron-builder": "^26.4.0",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-electron": "^0.29.0",
    "vue-tsc": "^3.2.2",
    "wait-on": "^9.0.3"
  }
}
