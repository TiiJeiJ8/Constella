{
  "name": "web",
  "private": true,
  "version": "v1.3.2",
  "description": "Constella - A visual workflow and node-based editing application",
  "author": "Constella Team",
  "type": "module",
  "main": "dist-electron/main.js",
  "engines": {
    "node": ">=20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "dev:electron": "vite",
    "dev:electron-no-backend": "cross-env SKIP_BACKEND=true vite",
    "version:bump": "node scripts/bump-version.cjs",
    "build": "vue-tsc -b && vite build",
    "build:server": "node scripts/build-server.cjs",
    "prepare:server-runtime": "node scripts/prepare-server-runtime.cjs",
    "prepare:node-runtime": "node scripts/prepare-node-runtime.cjs",
    "build:electron-main": "vite build",
    "build:electron": "npm run build:server && npm run prepare:server-runtime && npm run prepare:node-runtime && npm run build && electron-builder",
    "build:electron:installer": "npm run build:server && npm run prepare:server-runtime && npm run prepare:node-runtime && npm run build && electron-builder --win nsis --x64 --config.artifactName=Constella_${version}_${arch}-setup.${ext}",
    "build:electron:zip": "npm run build:server && npm run prepare:server-runtime && npm run prepare:node-runtime && npm run build && electron-builder --win zip --x64 --config.artifactName=Constella_${version}_${arch}.${ext}",
    "build:electron:portable": "npm run build:server && npm run prepare:server-runtime && npm run prepare:node-runtime && npm run build && electron-builder --win portable --x64 --config.artifactName=Constella_${version}_${arch}-portable.${ext}",
    "build:electron:release": "npm run build:electron:installer && npm run build:electron:zip",
    "build:electron:dir": "npm run build:server && npm run prepare:server-runtime && npm run prepare:node-runtime && npm run build && electron-builder --dir",
    "preview": "vite preview"
  },
  "build": {
    "appId": "com.constella.app",
    "productName": "Constella",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**",
      "dist-electron/**",
      "electron/**"
    ],
    "extraResources": [
      {
        "from": ".electron-server-runtime/dist",
        "to": "server/dist",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": ".electron-server-runtime/config",
        "to": "server/config",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": ".electron-server-runtime/node_modules",
        "to": "server/node_modules",
        "filter": [
          "!.bin"
        ]
      },
      {
        "from": ".electron-node-runtime/win-x64",
        "to": "node-runtime/win-x64",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "public/icon/favicon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.2",
    "@floating-ui/dom": "^1.7.6",
    "@marktext/file-icons": "^1.0.6",
    "@types/katex": "^0.16.8",
    "@types/markdown-it": "^14.1.2",
    "bonjour-service": "^1.3.0",
    "dompurify": "^3.3.1",
    "electron-store": "^11.0.2",
    "element-plus": "^2.13.0",
    "execall": "^3.0.0",
    "fast-diff": "^1.3.0",
    "flowchart.js": "^1.18.0",
    "fuse.js": "^7.4.2",
    "github-markdown-css": "^5.9.0",
    "highlight.js": "^11.11.1",
    "html-tags": "^5.1.0",
    "joplin-turndown-plugin-gfm": "^1.0.12",
    "katex": "^0.16.27",
    "konva": "^10.0.12",
    "lib0": "^0.2.117",
    "markdown-it": "^14.1.0",
    "marked": "^16.4.2",
    "marked-highlight": "^2.2.4",
    "mermaid": "^11.12.2",
    "ot-json1": "^1.0.2",
    "ot-text-unicode": "^4.0.0",
    "plantuml-encoder": "^1.4.0",
    "prismjs": "^1.30.0",
    "rxjs": "^7.8.2",
    "snabbdom": "^3.6.4",
    "snabbdom-to-html": "^7.1.0",
    "snapsvg-cjs": "^0.0.6",
    "tdesign-icons-vue-next": "^0.4.1",
    "turndown": "^7.2.4",
    "underscore": "^1.13.8",
    "vega": "^6.2.0",
    "vega-embed": "^7.1.0",
    "vega-lite": "^6.4.3",
    "vue": "^3.5.26",
    "vue-i18n": "^9.14.4",
    "vue-konva": "^3.3.0",
    "webfontloader": "^1.6.28",
    "y-websocket": "^3.0.0",
    "yjs": "^13.6.29"
  },
  "devDependencies": {
    "@types/bonjour": "^3.5.13",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^24.10.4",
    "@vitejs/plugin-vue": "^6.0.3",
    "@vue/tsconfig": "^0.8.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^39.8.10",
    "electron-builder": "^26.4.0",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-electron": "^0.29.0",
    "vue-tsc": "^3.2.2",
    "wait-on": "^9.0.3"
  }
}
